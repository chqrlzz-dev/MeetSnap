{
  "manifest_version": 3,
  "name": "MeetSnap — Google Meet Screenshot",
  "short_name": "MeetSnap",
  "description": "Capture and auto-download Google Meet screenshots with smart watermarking and diagnostic insights.",
  "version": "1.0.4",

  "permissions": [
    "tabs",
    "activeTab",
    "downloads",
    "storage",
    "https://meet.google.com/*"
  ],

  "host_permissions": [
    "https://meet.google.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js":  ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],

  "commands": {
    "capture-screenshot": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac":     "Command+Shift+S"
      },
      "description": "Capture a screenshot of the active Google Meet"
    }
  }
}
